{
  "name": "bingo-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend API para plataforma de Bingo",
  "main": "dist/app.js",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' tsx watch src/app.ts",
